{
  "name": "transform-text-to-filename",
  "displayName": "Transform text to filename",
  "publisher": "borzajuraj",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "repository":  {
    "type": "git",
    "url": "https://github.com/jborza/markdown-title.git"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
            "command": "markdown-title.textToFilename",
            "title": "Transform text to note filename"
        },
        {
            "command": "markdown-title.toList",
            "title": "Convert selection to unordered list"
        },
        {
            "command": "markdown-title.toCommaList",
            "title": "Convert selection to comma separated list"
        }
    ],
    "keybindings": [
        {
            "command": "markdown-title.textToFilename",
            "key": "ctrl+shift+t",
            "mac": "cmd+shift+t",
            "when": "editorTextFocus"
        },
        {
            "command": "markdown-title.toList",
            "key": "ctrl+shift+l",
            "mac": "cmd+shift+l",
            "when": "editorTextFocus"
        },
        {
            "command": "markdown-title.toCommaList",
            "key": "ctrl+shift+k",
            "mac": "cmd+shift+k",
            "when": "editorTextFocus"
        }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.52.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
